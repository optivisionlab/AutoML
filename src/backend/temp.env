### GENERAL SETTINGS ### 
# Minio
MINIO_ENDPOINT='localhost:9000' # Need when run worker, master
MINIO_ACCESS_KEY='' # Need when run worker, master
MINIO_SECRET_KEY='' # Need when run worker, master
PORT_BACK_END=8080
#==========================#
# Note: Use "::" for IPv6 to accept both IPv4 and IPv6 connections
HOST_BACK_END="::"
# If you build docker for worker server, IP must be able to ping the master server
# If you build docker for master server, IP should be 0.0.0.0
#==========================#

### WORKER SETTINGS ###
# Run worker server
WORKER_HOST="0.0.0.0"
WORKER_PORT=4000

### MASTER SETTINGS ###
HOST_SERVER="10.0.0.0"

# Configuration when running distributed in production
NUMBER_WORKERS=1

# Replace host and base port
WORKER_LIST='http://localhost:4000,http://localhost:4001,http://localhost:4002,http://localhost:4003' ...
# Because each worker will have a different IP

TASK_TIMEOUT_SECONDS=3600 # Time for master to check if worker is still active or not
MAX_TASK_SNOOZES=2 # Number of times a task can be snoozed before being considered failed

CLIENT_ID=""
CLIENT_SECRET=""
SESSION_TIMEOUT=60
HOST_FRONT_END="0.0.0.0"
PORT_FRONT_END="3000"
KAFKA_SERVER="localhost:9092"
KAFKA_TOPIC=""
MONGODB_CONNECT="localhost:27017"

SECRET_KEY = ""
ALGORITHM = ""
EXPIRE_MINUTES = 1
